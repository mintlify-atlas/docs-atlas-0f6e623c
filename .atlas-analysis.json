  "keyFeatures": [
    "30+ built-in plugins for authentication, authorization, and security",
    "Framework-agnostic design with adapters for Next.js, SvelteKit, Solid, and more",
    "30+ social OAuth providers (Google, GitHub, Apple, Discord, etc.)",
    "Database adapters for Prisma, Drizzle, Kysely, MongoDB",
    "Passwordless authentication (magic link, email OTP, phone OTP, passkeys)",
    "Enterprise SSO with SAML 2.0 and OIDC support",
    "Multi-tenant organizations with role-based access control",
    "Two-factor authentication (TOTP, backup codes)",
    "Multi-session management and custom session strategies",
    "OAuth Provider capabilities (turn your app into an IDP)",
    "Web3 authentication with Sign-In with Ethereum (SIWE)",
    "Comprehensive TypeScript support with full type safety",
    "CLI for project setup and database migrations"
  ],
  "publicApiSurface": [
    "betterAuth() - Main server initialization function",
    "createAuthClient() - Client library initialization",
    "useSession() - React hook for session management",
    "useAuth() - Framework-specific authentication hooks",
    "twoFactor - Two-factor authentication plugin",
    "organization - Multi-tenant organization plugin",
    "admin - Admin role and permissions plugin",
    "magicLink - Magic link authentication plugin",
    "emailOtp - Email OTP authentication plugin",
    "phoneNumber - Phone number authentication plugin",
    "passkey - WebAuthn/Passkey authentication plugin",
    "username - Username-based authentication plugin",
    "anonymous - Anonymous authentication plugin",
    "bearer - Bearer token authentication plugin",
    "siwe - Sign-In with Ethereum plugin",
    "access - Access control plugin",
    "multiSession - Multi-session management plugin",
    "customSession - Custom session strategy plugin",
    "genericOauth - Generic OAuth provider plugin",
    "oauthProxy - OAuth proxy plugin",
    "oidcProvider - OIDC provider plugin",
    "jwt - JWT token plugin",
    "haveibeenpwned - Password breach detection plugin",
    "oneTimeToken - One-time token plugin",
    "deviceAuthorization - Device authorization flow plugin",
    "prismaAdapter() - Prisma ORM adapter",
    "drizzleAdapter() - Drizzle ORM adapter",
    "kyselyAdapter() - Kysely adapter",
    "mongoAdapter() - MongoDB adapter",
    "github - GitHub OAuth provider",
    "google - Google OAuth provider",
    "apple - Apple OAuth provider",
    "discord - Discord OAuth provider",
    "microsoft - Microsoft OAuth provider",
    "twitter - Twitter OAuth provider"
  ]
