  "keyFeatures": [
    "35+ OAuth providers including Google, GitHub, Discord, Microsoft, Apple, and more",
    "Multiple authentication methods: email/password, magic links, OTP, passkeys, Web3",
    "Enterprise features: SSO (SAML/OIDC), SCIM 2.0, multi-tenancy, RBAC",
    "Framework-agnostic with React, Vue, Svelte, Solid support",
    "30+ built-in plugins for extensibility",
    "Database flexibility with Prisma, Drizzle, Kysely, MongoDB adapters",
    "Full TypeScript support with type inference",
    "Built-in CLI for migrations and setup",
    "Session management with multiple strategies",
    "Advanced security features: 2FA, rate limiting, CSRF protection, password breach detection"
  ],
  "publicApiSurface": [
    "betterAuth() - Main server initialization",
    "createAuthClient() - Client SDK initialization",
    "better-auth/react - React hooks (useSession, useSignIn, useSignUp)",
    "better-auth/vue - Vue composables",
    "better-auth/svelte - Svelte stores",
    "better-auth/solid - Solid primitives",
    "better-auth/plugins - Built-in plugins",
    "better-auth/social-providers - OAuth provider configs",
    "better-auth/adapters/* - Database adapters",
    "@better-auth/sso - SSO plugin (SAML/OIDC)",
    "@better-auth/scim - SCIM 2.0 plugin",
    "@better-auth/passkey - Passkey/WebAuthn plugin",
    "@better-auth/stripe - Stripe integration plugin",
    "@better-auth/oauth-provider - OAuth provider plugin",
    "@better-auth/i18n - Internationalization plugin",
    "@better-auth/redis-storage - Redis secondary storage",
    "@better-auth/expo - Expo/React Native integration",
    "@better-auth/electron - Electron app integration",
    "auth CLI - Command-line tool for migrations and setup"
  ]
}
